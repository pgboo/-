<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.paotui.mapper.AdminMapper">
    <resultMap id="BaseResultMap" type="com.paotui.entity.Admin">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="name" property="name"/>
        <result column="role" property="role"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, username, password, name, role, create_time
    </sql>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from admin where id = #{id}
    </select>

    <select id="login" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from admin
        where username = #{username} and password = #{password} and role = 'admin'
    </select>

    <select id="selectAll" resultMap="BaseResultMap" parameterType="java.util.Map">
        select <include refid="Base_Column_List"/> from admin
        <where>
            <if test="keyword != null and keyword != ''">
                and (username like concat('%',#{keyword},'%') or name like concat('%',#{keyword},'%'))
            </if>
        </where>
        order by id desc
    </select>

    <delete id="deleteByPrimaryKey">
        delete from admin where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.paotui.entity.Admin" useGeneratedKeys="true" keyProperty="id">
        insert into admin (username, password, name, role, create_time)
        values (#{username}, #{password}, #{name}, #{role}, now())
    </insert>

    <insert id="insertSelective" parameterType="com.paotui.entity.Admin" useGeneratedKeys="true" keyProperty="id">
        insert into admin
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="username != null">username,</if>
            <if test="password != null">password,</if>
            <if test="name != null">name,</if>
            <if test="role != null">role,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="username != null">#{username},</if>
            <if test="password != null">#{password},</if>
            <if test="name != null">#{name},</if>
            <if test="role != null">#{role},</if>
            now(),
        </trim>
    </insert>

    <update id="updateByPrimaryKeySelective" parameterType="com.paotui.entity.Admin">
        update admin
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="name != null">name = #{name},</if>
            <if test="role != null">role = #{role},</if>
        </set>
        where id = #{id}
    </update>

    <update id="updateByPrimaryKey" parameterType="com.paotui.entity.Admin">
        update admin set username = #{username}, password = #{password}, name = #{name}, role = #{role}
        where id = #{id}
    </update>
</mapper>
