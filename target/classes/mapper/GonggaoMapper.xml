<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.paotui.mapper.GonggaoMapper">
    <resultMap id="BaseResultMap" type="com.paotui.entity.Gonggao">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, title, content, create_time
    </sql>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from gonggao where id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap" parameterType="java.util.Map">
        select <include refid="Base_Column_List"/> from gonggao
        <where>
            <if test="keyword != null and keyword != ''">
                and (title like concat('%',#{keyword},'%') or content like concat('%',#{keyword},'%'))
            </if>
        </where>
        order by id desc
    </select>

    <delete id="deleteByPrimaryKey">
        delete from gonggao where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.paotui.entity.Gonggao" useGeneratedKeys="true" keyProperty="id">
        insert into gonggao (title, content, create_time) values (#{title}, #{content}, now())
    </insert>

    <insert id="insertSelective" parameterType="com.paotui.entity.Gonggao" useGeneratedKeys="true" keyProperty="id">
        insert into gonggao
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null">title,</if>
            <if test="content != null">content,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null">#{title},</if>
            <if test="content != null">#{content},</if>
            now(),
        </trim>
    </insert>

    <update id="updateByPrimaryKeySelective" parameterType="com.paotui.entity.Gonggao">
        update gonggao
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
        </set>
        where id = #{id}
    </update>

    <update id="updateByPrimaryKey" parameterType="com.paotui.entity.Gonggao">
        update gonggao set title = #{title}, content = #{content} where id = #{id}
    </update>

    <update id="updateByPrimaryKeyWithBLOBs" parameterType="com.paotui.entity.Gonggao">
        update gonggao set title = #{title}, content = #{content} where id = #{id}
    </update>
</mapper>
