<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.paotui.mapper.UserMapper">
    <resultMap id="BaseResultMap" type="com.paotui.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="name" property="name"/>
        <result column="phone" property="phone"/>
        <result column="avatar" property="avatar"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, username, password, name, phone, avatar, status, create_time
    </sql>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from user where id = #{id}
    </select>

    <select id="login" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from user
        where username = #{username} and password = #{password} and status = 1
    </select>

    <select id="selectByUsername" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from user where username = #{username}
    </select>

    <select id="selectAll" resultMap="BaseResultMap" parameterType="java.util.Map">
        select <include refid="Base_Column_List"/> from user
        <where>
            <if test="keyword != null and keyword != ''">
                and (username like concat('%',#{keyword},'%') or name like concat('%',#{keyword},'%') or phone like concat('%',#{keyword},'%'))
            </if>
            <if test="status != null">and status = #{status}</if>
        </where>
        order by id desc
    </select>

    <delete id="deleteByPrimaryKey">
        delete from user where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.paotui.entity.User" useGeneratedKeys="true" keyProperty="id">
        insert into user (username, password, name, phone, avatar, status, create_time)
        values (#{username}, #{password}, #{name}, #{phone}, #{avatar}, 1, now())
    </insert>

    <insert id="insertSelective" parameterType="com.paotui.entity.User" useGeneratedKeys="true" keyProperty="id">
        insert into user
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="username != null">username,</if>
            <if test="password != null">password,</if>
            <if test="name != null">name,</if>
            <if test="phone != null">phone,</if>
            <if test="avatar != null">avatar,</if>
            <if test="status != null">status,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="username != null">#{username},</if>
            <if test="password != null">#{password},</if>
            <if test="name != null">#{name},</if>
            <if test="phone != null">#{phone},</if>
            <if test="avatar != null">#{avatar},</if>
            <if test="status != null">#{status},</if>
            now(),
        </trim>
    </insert>

    <update id="updateByPrimaryKeySelective" parameterType="com.paotui.entity.User">
        update user
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="name != null">name = #{name},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where id = #{id}
    </update>

    <update id="updateByPrimaryKey" parameterType="com.paotui.entity.User">
        update user set username = #{username}, password = #{password}, name = #{name}, phone = #{phone},
        avatar = #{avatar}, status = #{status} where id = #{id}
    </update>
</mapper>
